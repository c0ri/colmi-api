# Colmi Ring BLE address (required)
# Find with: colmi_r02_client scan
COLMI_ADDRESS=XX:XX:XX:XX:XX:XX

# Full path to colmi_r02_client binary
COLMI_BIN=/home/pi/.local/bin/colmi_r02_client

# HTTP server port (default 8080)
PORT=8080

# CLI timeout per command in seconds (default 45)
COLMI_TIMEOUT=45
